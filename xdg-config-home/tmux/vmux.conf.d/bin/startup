#!/bin/zsh

export MMUX="$TMUX"
export MMUX_PANE="$TMUX_PANE"

rundir="${XDG_RUNTIME_HOME-${HOME}/.cache}/tmux/vmux"
mkdir -p "$rundir"
chmod 0700 "$rundir"

dumb clone aweager/mux-bar
if [[ ! -x "$DUMB_CLONE_HOME/mux-bar/bin/mux-bar" ]]; then
    make -C "$DUMB_CLONE_HOME/mux-bar"
fi
tmux split-window -hbd -l 15 "zsh -ic ${DUMB_CLONE_HOME}/mux-bar/bin/mux-bar 2>/dev/null"

session_name=$(tmux display-message -p '#S')

unset TMUX
unset TMUX_PANE
tmux -L vmux_managed -f "${XDG_CONFIG_HOME}/tmux/vmux.conf" new-session -s "$session_name"
